GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_DEV=gemini-2.5-flash-lite

SESSION_SECRET=generate_random_secret
IP_HASH_SECRET=generate_random_secret

ADMIN_EMAILS=["[your_email@gmail.com](mailto:your_email@gmail.com)"]

APP_NAME=DestekAI RAG API
APP_ENV=development
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:8000","http://localhost:5500"]

DATABASE_URL=postgresql+asyncpg://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_rag
EMBEDDING_DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_rag
DB_ECHO=false
AUTO_CREATE_TABLES=true

SESSION_COOKIE_NAME=destekai_session
SESSION_TTL_HOURS=168

EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL=hashing-sha256-v1
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu
EMBEDDING_INGEST_VERSION=1

SEARCH_LIMIT=10
MIN_RETRIEVAL_SCORE=0.55
HASHING_MIN_RETRIEVAL_SCORE=0.30
CONFIDENCE_HIGH_THRESHOLD=0.78
CONFIDENCE_MEDIUM_THRESHOLD=0.62

LLM_PROVIDER=gemini
LLM_TIMEOUT_SECONDS=60
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_SECONDS=1.0
GEMINI_PROMPT_COST_PER_MILLION=
GEMINI_COMPLETION_COST_PER_MILLION=

CLASSIFIER_PROVIDER=rule_based
CLASSIFIER_FALLBACK_PROVIDER=rule_based

SIMILAR_SOLUTION_MIN_VIEWS=10
SIMILAR_SOLUTION_MIN_HELPFUL=5
SIMILAR_SOLUTION_MIN_SUCCESS_RATE=0.80

MAX_QUERY_LENGTH=1000
MAX_TICKET_NOTE_LENGTH=1000
CHAT_RATE_LIMIT=20
CHAT_RATE_WINDOW_SECONDS=600
FEEDBACK_RATE_LIMIT=30
FEEDBACK_RATE_WINDOW_SECONDS=3600
TICKET_DAILY_LIMIT=5

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
