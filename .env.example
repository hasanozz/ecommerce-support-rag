APP_NAME=DestekAI RAG API
APP_ENV=development
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:8000","http://localhost:5500"]

DATABASE_URL=postgresql+asyncpg://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_rag
EMBEDDING_DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_rag
DB_ECHO=false
AUTO_CREATE_TABLES=true

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu

SEARCH_LIMIT=10
MIN_RETRIEVAL_SCORE=0.55

LLM_PROVIDER=disabled
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=60

MAX_QUERY_LENGTH=1000
